			/* Font CSS */ 
@font-face {
  font-family: Anuyart;
  src: url('/wp-content/uploads/2023/10/Anuyart-Light.woff2') format('woff2');
  font-weight: 300;
}

/* Regular Font */
@font-face {
  font-family: Anuyart;
  src: url('/wp-content/uploads/2023/10/Anuyart-Regular.woff2') format('woff2');
  font-weight: 400;
}

/* Bold Font */
@font-face {
  font-family: Anuyart;
  src: url('/wp-content/uploads/2023/10/Anuyart-Bold.woff2') format('woff2');
  font-weight: 700;
}

/* Body Font */ 
body {
  font-family: Anuyart;
  font-weight: 400; 
}
p {
  font-family: Anuyart;
  font-weight: 400; 
}

/* Apply Bold Font */
h1, h2, h3, h4, h5, h6, a {
  font-family: Anuyart;
  font-weight: 700; 
}

.thin {
	font-weight:300!important;
}

 @media (min-width: 1024px) {
/* CSS FILTERS */ 
form.searchandfilter ul {
  display:flex;
  align-items:center;
  justify-content:space-between;
  list-style:none;
  margin:30px 0;
  padding:10px; 
  background:#fff;
  border:1px solid #BDBDBD;
  border-radius:5px;
}
form.searchandfilter li {
  margin:0 10px;
  background:#fff;
}
.postform {
  border:none;
}
select.postform {
  font-size:14px;
  text-align:right;
}
.searchandfilter input  {
  border:none!important;
}
 .searchandfilter input[type="hidden"] {
 text-align:left!important;
   }
.searchandfilter input[type="submit"] {
  background:#ED1C24!important;;
  color:#fff;
  padding:10px 30px;
}
.search-panel.active {
  border:none;
}
.level-0 {
  font-size:12px;
}
}
 @media (max-width: 1023px) {

.searchandfilter {
 padding:30px 0;
}
.searchandfilter ul {
  list-style:none;
	display:grid;
}
.searchandfilter li {
  margin:10px 0; 
}
.searchandfilter input {
  width:100%!important;
  background:#fff;
}
.postform {
  width:100%;
  background:#fff;
}
.searchandfilter input[type="submit"] {
  background:#0078C0;
  height:50px;
  border:none;
  color:#fff;
  padding:10px 30px;
}
}

/* Search BAR CSS */
.search-panel.active {
  background:#F2F2F2; 
}
.search-panel.active .s-container {
  max-width:600px;
}
.ascend-search-form {
  display:flex; 
  background:#fff;
  border:1px solid #BDBDBD;
  max-width:600px;
}
#s {
  color:#828282;
  margin:0 30px;
}
.custom-placeholder-color::placeholder {
    color:#828282!important;
    font-size:15px;
}
.search-submit {
  margin:3px;
  background:#ED1C24;
  color:#fff;
  border:none;
  border-radius:3px;
  padding:5px 15px; 
}

/* Mobile Header */
@media (max-width: 1023px) {
.nav-panel ul ul li a {
  font-weight:300;
}
}

.nav-panel.-right.active {
	border-radius:0;
}

/* 11/16/2023 CSS */ 
.quote-content {
	margin:10px 30px!important;
}

/* 11/24/2023 CSS About us */
.kadence-column10_f3aa12-7c > .kt-inside-inner-col {
  height:100%;
}

.accordion-image-desktop {
    max-height: 80px;
    margin:0!important;
		margin-bottom:40px!important;
}

/*Footer Css for product link*/
.productfooter a{
	font-weight: 400!important;
}

/* 12/2/2024 About us BG css */
.kadence-column10_e79c0d-3e > .kt-inside-inner-col {
  height:100%;
} 

/* 15/1/2025 */

.popup-wrapper {
  align-items:center;
  background:#fff;
	border-radius:5px;
	gap:10px;
}

.pum-container {
  border:none!important;
  padding:0!important;
	box-shadow:none!important;
}
.popup-text-wrapper {
  padding:7%;
  color:#4F4F4F;
}

.popup-image {
  height:100%;

}
.popup-image img {
  width:100%!important;
  height:100%!important;
  object-fit:cover!important;
}

html.pum-open.pum-open-overlay.pum-open-scrollable body>:not([aria-modal=true]) {
	padding-right:0!important;
}

.popup-wrapper .material-symbols-outlined {
  color:#ED1C24!important;
  font-size:30px!important;
  font-weight:bold!important;
}

.pum-theme-2817 .pum-content + .pum-close, .pum-theme-default-theme .pum-content + .pum-close {
  background:#fff!important;
  color:#000!important;
}

@media (max-width:1023px) {
  .popup-image {
display:none!important;
	}
	.pum-theme-2818 .pum-content + .pum-close, .pum-theme-lightbox .pum-content + .pum-close {
		right:-3px!important;
	}
}

/* popup CSS 2/3/25 */ 

.pum-container {
 background:none!important; 
}
.popmake-content {
  text-align:center!important;
}

.pum-container {
  width: fit-content !important;
}

/* paging css */
.s-paging {
	margin-top:30px!important;
}

/* Hide */
.home-quotes-section-gallery-wrapper {
	display:none!important;
}		</style>
